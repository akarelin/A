#!/bin/bash
# SessionSkills HITL review CLI
set -e
for b in \
  /Users/alex/RAN/AI/SessionManager/bin/_bootstrap.sh \
  /Users/alex/A/SessionManager/bin/_bootstrap.sh \
  /home/alex/SessionManager/bin/_bootstrap.sh \
  /home/alex/A/SessionManager/bin/_bootstrap.sh; do
  if [ -r "$b" ]; then source "$b"; break; fi
done
if [ -z "${SM_PY:-}" ]; then echo "SessionManager bootstrap not found" >&2; exit 1; fi
for repo in /Users/alex/A/SessionManager /home/alex/A/SessionManager; do
  if [ -d "$repo/sessions" ]; then SS_REPO="$repo"; break; fi
done
cd "$SS_REPO"
exec "$SM_PY" -m sessions.review_tui "$@"
