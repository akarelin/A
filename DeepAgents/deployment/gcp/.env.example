# LangChain/LangSmith Configuration
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=deepagents-production

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DB_PASSWORD=your_secure_database_password_here

# Repository Path (optional, defaults to /home/ubuntu/repos)
REPO_PATH=/home/ubuntu/repos

# DeepAgents Model (optional, defaults to openai:gpt-4o)
DEEPAGENTS_MODEL=openai:gpt-4o
