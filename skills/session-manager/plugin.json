{
  "name": "session-manager",
  "version": "0.1.0",
  "description": "Manage Claude session folders across repos and hosts.",
  "entrypoint": "python3 claude_session_manager.py",
  "commands": {
    "sync": "python3 claude_session_manager.py sync",
    "sync-all": "python3 claude_session_manager.py sync-all",
    "pull-latest": "python3 claude_session_manager.py pull-latest --all",
    "list": "python3 claude_session_manager.py list",
    "list-current": "python3 claude_session_manager.py list --current",
    "delete-empty": "python3 claude_session_manager.py delete-empty --apply"
  }
}
