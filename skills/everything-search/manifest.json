{
  "manifest_version": "0.2",
  "name": "Everything Search",
  "version": "0.1.0",
  "description": "Fast file search using voidtools Everything (1.4 and 1.5a) via es.exe CLI.",
  "author": { "name": "essovius (repackaged by akarelin)" },
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "env": {
        "EVERYTHING_INSTANCE": "${user_config.everything_instance}",
        "PATH": "${user_config.es_exe_dir};${env:PATH}"
      }
    }
  },
  "user_config": {
    "everything_instance": {
      "type": "string",
      "title": "Everything Instance",
      "description": "Instance name for Everything 1.5a. Leave empty for Everything 1.4.",
      "default": "1.5a",
      "required": false
    },
    "es_exe_dir": {
      "type": "string",
      "title": "es.exe Directory",
      "description": "Folder containing es.exe (Everything command-line tool).",
      "default": "C:\\Program Files\\Everything 1.5a",
      "required": true
    }
  },
  "compatibility": { "platforms": ["win32"] }
}
